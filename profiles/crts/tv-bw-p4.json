{
  "$schema": "../../schemas/crt_profile.schema.json",
  "id": "tv-bw-p4",
  "display_name": "Vintage B&W TV — P4 (1960s-70s living-room set)",
  "era": "1970",

  "tube": {
    "mask_type": "none",
    "dot_pitch_mm": null,
    "screen_curvature": "aggressive",
