    },
    "source": {
      "url": "https://en.wikipedia.org/wiki/Phosphor",
      "retrieved_at": "2026-05-26",
      "notes": "P4 = white phosphor; short persistence. Representative decay 0.5 ms. Chromaticity approximated near CIE white point (0.29, 0.32)."
    }
  },

  "beam": {
    "focus": 0.55,
    "intensity_curve": "gauss",
