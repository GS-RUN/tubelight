{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "tubelight",
  "version": "0.1.0",
  "description": "High-fidelity CRT overlay for Windows and Linux",
  "homepage": "https://github.com/gs-run/tubelight",
  "license": "MIT",
  "supports": "(windows | linux) & x64",
  "dependencies": [
    "glfw3",
    "libepoxy",
    "glm",
    "stb",
    "nlohmann-json"
  ],
  "features": {
    "shaders-advanced": {
      "description": "GLSL→SPIR-V→HLSL cross-compilation for F6 (Vulkan + DX12)",
      "dependencies": [
        "glslang",
        "spirv-cross"
      ]
    },
    "ui": {
      "description": "Dear ImGui control panel (F3+)",
      "dependencies": [
        {
          "name": "imgui",
          "features": ["glfw-binding", "opengl3-binding"]
        }
      ]
    },
    "injection": {
      "description": "DLL injection for Present() hook on Windows (F5+)",
      "dependencies": [
        {
          "name": "minhook",
          "platform": "windows"
        }
      ]
    }
  },
  "default-features": []
}
